# Copy this file to .env and fill in the values you need. mise auto-loads
# .env (and .env.local, which wins) when you enter the project directory.
# Both files are gitignored — never commit secrets.

# --- LangSmith observability (optional) ---
# When LANGSMITH_API_KEY is set, every LLM call streams traces to LangSmith.
# Leave unset to disable tracing entirely (zero runtime cost).
# LANGSMITH_API_KEY=lsv2_pt_...
# LANGSMITH_PROJECT=canvas-chat-dev

# --- Provider API keys (only needed in admin mode; otherwise configure in UI) ---
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=
# GROQ_API_KEY=
# PERPLEXITY_API_KEY=

# --- Logging ---
# LOG_LEVEL=DEBUG
# LITELLM_LOG=DEBUG
